# Recall gateway — Podman Quadlet (rootless)
# Installed by scripts/podman/setup.sh into recall's ~/.config/containers/systemd/
# {{RECALL_HOME}} is replaced at install time.

[Unit]
Description=Recall gateway (rootless Podman)

[Container]
Image=recall:local
ContainerName=recall
UserNS=keep-id
# Keep container UID/GID aligned with the invoking user so mounted config is readable.
User=%U:%G
Volume={{RECALL_HOME}}/.recall:/home/node/.recall:Z
EnvironmentFile={{RECALL_HOME}}/.recall/.env
Environment=HOME=/home/node
Environment=TERM=xterm-256color
PublishPort=18789:18789
PublishPort=18790:18790
Pull=never
Exec=node dist/index.js gateway --bind lan --port 18789

[Service]
TimeoutStartSec=300
Restart=on-failure

[Install]
WantedBy=default.target
